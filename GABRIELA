<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Para Gabriela 💖</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: white;
            overflow-x: hidden;
            background: linear-gradient(270deg, #ff4757, #ff3838, #ff6b6b, #ffa502, #ff9ff3, #ff7675);
            background-size: 1200% 1200%;
            animation: gradientBG 8s ease infinite;
            position: relative;
            min-height: 100vh;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            25% { background-position: 50% 0%; }
            50% { background-position: 100% 50%; }
            75% { background-position: 50% 100%; }
            100% { background-position: 0% 50%; }
        }

        .container {
            position: relative;
            z-index: 10;
            padding: 20px;
            text-align: center;
        }

        .floating-hearts {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .heart-particle {
            position: absolute;
            color: #ff4757;
            animation: float 6s infinite linear;
            opacity: 0;
        }

        @keyframes float {
            0% {
                opacity: 0;
                transform: translateY(100vh) scale(0);
            }
            10% {
                opacity: 1;
                transform: translateY(90vh) scale(1);
            }
            90% {
                opacity: 1;
                transform: translateY(10vh) scale(1);
            }
            100% {
                opacity: 0;
                transform: translateY(-10vh) scale(0);
            }
        }

        .sparkle {
            position: fixed;
            width: 4px;
            height: 4px;
            background: white;
            border-radius: 50%;
            pointer-events: none;
            z-index: 2;
            animation: sparkle 2s infinite;
        }

        @keyframes sparkle {
            0%, 100% { opacity: 0; transform: scale(0); }
            50% { opacity: 1; transform: scale(1); }
        }

        h1 {
            font-size: clamp(2em, 8vw, 4em);
            margin: 30px 0;
            text-shadow: 3px 3px 20px rgba(0,0,0,0.7);
            animation: titleGlow 3s ease-in-out infinite alternate;
            background: linear-gradient(45deg, #ff4757, #ff3838, #ff4757, #ffeaa7);
            background-size: 300% 300%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: titleGlow 3s ease-in-out infinite alternate, gradientText 4s ease infinite;
        }

        @keyframes titleGlow {
            from { filter: drop-shadow(0 0 10px rgba(255, 71, 87, 0.8)); }
            to { filter: drop-shadow(0 0 25px rgba(255, 71, 87, 1)) drop-shadow(0 0 35px rgba(255, 71, 87, 0.8)); }
        }

        @keyframes gradientText {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .message-card {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 25px;
            padding: 25px;
            margin: 20px auto;
            max-width: 600px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            transform: translateY(50px);
            opacity: 0;
            animation: slideInUp 1s ease forwards;
            position: relative;
            overflow: hidden;
        }

        .message-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            animation: shine 3s infinite;
        }

        @keyframes shine {
            0% { left: -100%; }
            100% { left: 100%; }
        }

        @keyframes slideInUp {
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .message-card:nth-child(2) { animation-delay: 0.2s; }
        .message-card:nth-child(3) { animation-delay: 0.4s; }
        .message-card:nth-child(4) { animation-delay: 0.6s; }
        .message-card:nth-child(5) { animation-delay: 0.8s; }
        .message-card:nth-child(6) { animation-delay: 1s; }

        .heart {
            font-size: 2.5em;
            animation: heartbeat 2s infinite;
            display: inline-block;
            margin: 10px;
        }

        @keyframes heartbeat {
            0%, 50%, 100% { transform: scale(1); }
            25% { transform: scale(1.3) rotate(5deg); }
            75% { transform: scale(1.1) rotate(-5deg); }
        }

        .rose {
            font-size: 1.8em;
            animation: sway 4s ease-in-out infinite;
            display: inline-block;
        }

        @keyframes sway {
            0%, 100% { transform: rotate(-5deg); }
            50% { transform: rotate(5deg); }
        }

        .music-control {
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(255, 255, 255, 0.2);
            border: none;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            font-size: 1.5em;
            color: white;
            cursor: pointer;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
            z-index: 100;
        }

        .music-control:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: scale(1.1);
        }

        .love-message {
            font-size: 1.4em;
            line-height: 1.6;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
        }

        .code-joke {
            background: rgba(0, 0, 0, 0.4);
            border-radius: 15px;
            padding: 20px;
            margin: 15px 0;
            border-left: 4px solid #ff4757;
            font-family: 'Courier New', monospace;
        }

        .floating-emoji {
            position: fixed;
            pointer-events: none;
            z-index: 5;
            animation: floatEmoji 8s infinite linear;
        }

        @keyframes floatEmoji {
            0% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-100px) rotate(360deg);
                opacity: 0;
            }
        }

        .btn-surprise {
            background: linear-gradient(45deg, #ff4757, #ff3838);
            border: none;
            padding: 15px 30px;
            border-radius: 25px;
            color: white;
            font-size: 1.2em;
            cursor: pointer;
            margin: 20px;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(255, 71, 87, 0.4);
        }

        .btn-surprise:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(255, 71, 87, 0.6);
        }

        .surprise-message {
            display: none;
            background: linear-gradient(45deg, #ff4757, #ff3838, #ff4757);
            background-size: 200% 200%;
            animation: gradientShift 2s ease infinite;
            padding: 20px;
            border-radius: 20px;
            margin: 20px 0;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @media (max-width: 768px) {
            .message-card {
                margin: 10px;
                padding: 20px;
            }
            
            .love-message {
                font-size: 1.2em;
            }
        }
    </style>
</head>
<body>
    <!-- Música "Vivo por tu amor" - Caribeños de Guadalupe -->
    <audio id="backgroundMusic" autoplay loop preload="auto" style="display: none;">
        <source src="https://www.dropbox.com/scl/fi/gt1qsoru28niqwgp7nmug/V-deo-sin-t-tulo-Hecho-con-Clipchamp.mp3?rlkey=834ada5mqspngtp21rlulgdil&st=gicxuksv&dl=1" type="audio/mpeg">
        Tu navegador no soporta audio.
    </audio>

    <button class="music-control" onclick="toggleMusic()" id="musicBtn" style="display: none;">🎵</button>

    <div class="floating-hearts" id="heartsContainer"></div>
    
    <div class="container">
        <h1>💖 Para Gabriela 💖</h1>
        
        <div class="message-card">
            <div class="heart">💝</div>
            <div class="love-message">
                <span class="rose">🌹</span> Hola mi Hermosa Princesa <span class="rose">🌷</span>
            </div>
        </div>

        <div class="message-card">
            <div class="love-message">
                Este código fue escrito con mucho amor, cada línea pensada en ti ✨
                <br>Como un algoritmo perfecto que siempre me lleva a tu corazón 💕
            </div>
        </div>

        <div class="message-card">
            <div class="code-joke">
                <strong>🤓 Chiste romántico para ti:</strong><br>
                ¿Sabes por qué eres como la WiFi de mi casa?<br>
                <em>¡Porque sin ti no tengo conexión con la felicidad! 📶😄</em>
            </div>
        </div>

        <div class="message-card">
            <div class="love-message">
                💐 Eres la estrella más brillante en mi cielo nocturno<br>
                🌟 Más hermosa que un amanecer en primavera<br>
                💖 Y más dulce que la miel de las flores más fragantes
            </div>
        </div>

        <div class="message-card">
            <div class="code-joke">
                <strong>💕 Un verso para ti:</strong><br>
                <em>"Eres como la luna en mi noche oscura,<br>
                iluminas mi camino con tu hermosura,<br>
                tu sonrisa es la melodía más pura,<br>
                que hace latir mi corazón con ternura." 🌙✨</em>
            </div>
        </div>

        <div class="message-card">
            <button class="btn-surprise" onclick="showSurprise()">✨ ¡Haz click para una sorpresa! ✨</button>
            <div class="surprise-message" id="surpriseMsg">
                <div class="heart">💖</div>
                <strong>¡SORPRESA!</strong><br>
                Eres el sol que ilumina mis días<br>
                Y la luna que acompaña mis noches 🌙<br>
                Mi corazón late solo por ti 🥰<br>
                <div class="heart">💕</div>
            </div>
        </div>
    </div>

    <script>
        // Auto-reproducir música al cargar la página
        window.addEventListener('load', function() {
            const music = document.getElementById('backgroundMusic');
            music.volume = 0.7; // Volumen al 70%
            
            // Intentar reproducir inmediatamente
            music.play().catch(function() {
                // Si no se puede reproducir automáticamente, intentar después del primer clic
                document.addEventListener('click', function() {
                    music.play().catch(e => console.log("No se puede reproducir música"));
                }, { once: true });
            });
        });

        // Control de música (función simplificada)
        function toggleMusic() {
            const music = document.getElementById('backgroundMusic');
            
            if (music.paused) {
                music.play().catch(e => console.log("No se puede reproducir música"));
            } else {
                music.pause();
            }
        }

        // Crear corazones flotantes
        function createFloatingHeart() {
            const heart = document.createElement('div');
            heart.className = 'heart-particle';
            heart.innerHTML = ['💖', '💕', '💗', '💓', '❤️', '🌹', '✨'][Math.floor(Math.random() * 7)];
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.fontSize = (Math.random() * 20 + 15) + 'px';
            heart.style.animationDuration = (Math.random() * 3 + 4) + 's';
            
            document.getElementById('heartsContainer').appendChild(heart);
            
            setTimeout(() => {
                heart.remove();
            }, 6000);
        }

        // Crear estrellitas que siguen el mouse
        function createSparkle(e) {
            const sparkle = document.createElement('div');
            sparkle.className = 'sparkle';
            sparkle.style.left = e.clientX + 'px';
            sparkle.style.top = e.clientY + 'px';
            document.body.appendChild(sparkle);
            
            setTimeout(() => {
                sparkle.remove();
            }, 2000);
        }

        // Mostrar mensaje sorpresa
        function showSurprise() {
            const surprise = document.getElementById('surpriseMsg');
            surprise.style.display = 'block';
            surprise.style.animation = 'slideInUp 0.5s ease forwards';
            
            // Crear explosión de corazones
            for (let i = 0; i < 15; i++) {
                setTimeout(createFloatingHeart, i * 100);
            }
        }

        // Crear emojis flotantes aleatorios
        function createRandomEmoji() {
            const emojis = ['🦋', '🌸', '🌺', '💫', '⭐', '🌙', '🎀', '💎'];
            const emoji = document.createElement('div');
            emoji.className = 'floating-emoji';
            emoji.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
            emoji.style.left = Math.random() * 100 + 'vw';
            emoji.style.fontSize = (Math.random() * 15 + 20) + 'px';
            emoji.style.animationDuration = (Math.random() * 4 + 6) + 's';
            
            document.body.appendChild(emoji);
            
            setTimeout(() => {
                emoji.remove();
            }, 8000);
        }

        // Funciones para las animaciones (mantener las que estaban)
        setInterval(createFloatingHeart, 800);
        setInterval(createRandomEmoji, 2000);
        
        // Agregar eventos
        document.addEventListener('mousemove', createSparkle);
    </script>
</body>
</html>
